@using HRWebApp.Models
@model IEnumerable<EmployeeViewModel>

@{
    ViewBag.Title = "Executive Dashboard";
}

<div class="content">
    <div class="btn-controls">
        <div class="btn-box-row row-fluid">
            <div class="btn-box big span4">
                <i class="icon-random"></i><b>Data Tool</b>
                <p class="text-muted">Quản trị tích hợp</p>
                <div style="margin-top:10px;">
                    <a href="@Url.Action("SeedData", "Admin")" class="btn btn-primary btn-small">Tải xuống dữ liệu hệ thống.</a>
                </div>
            </div>

            <a href="#" class="btn-box big span4">
                <i class="icon-user"></i>
                <b>@String.Format("{0:N0}", ViewBag.TotalUsers ?? 0)</b>
                <p class="text-muted">Tổng nhân sự (HR System) và hệ thống tính lương (Payroll)</p>
            </a>

            <a href="#" class="btn-box big span4">
                <i class="icon-money"></i>
                <b>@ViewBag.TotalSalary</b>
                <p class="text-muted">Tổng quỹ lương (Payroll System)</p>
            </a>
        </div>

        <div class="btn-box-row row-fluid">
            <div class="span12">
                <div class="module">
                    <div class="module-head"><h3>Cảnh báo quản trị</h3></div>
                    <div class="module-body">
                        <div class="row-fluid">
                            <a href="@Url.Action("AlertAnniversary", "Admin")" class="btn-box small span4">
                                <i class="icon-time"></i><b>Kỷ niệm vào làm</b>
                            </a>
                            <a href="@Url.Action("AlertVacation", "Admin")" class="btn-box small span4">
                                <i class="icon-plane"></i><b>Nghỉ phép > 25 ngày</b>
                            </a>
                            <a href="@Url.Action("AlertBirthday", "Admin")" class="btn-box small span4">
                                <i class="icon-gift"></i><b>Sinh nhật tháng @DateTime.Now.Month</b>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="module">
        <div class="module-head"><h3>Cơ cấu nhân sự (Real-time)</h3></div>
        <div class="module-body">
            <div id="placeholder2" class="graph" style="height: 350px"></div>
        </div>
    </div>

    <div class="module">
        <div class="module-head"><h3>Danh sách nhân sự tích hợp</h3></div>
        <div class="module-body table">
            <table cellpadding="0" cellspacing="0" border="0" class="datatable-1 table table-bordered table-striped display" width="100%">
                <thead>
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ và Tên</th>
                        <th>Giới tính</th>
                        <th>Dân tộc</th>
                        <th>Lương (Pay Rate)</th>
                        <th>Ngày nghỉ phép</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr class="odd gradeX">
                                <td>@item.ID</td>
                                <td>@item.FullName</td>
                                <td>@item.Gender</td>
                                <td>@item.Ethnicity</td>
                                <td class="center">@String.Format("{0:N0}", item.Salary) $</td>
                                <td class="center">@item.Vacation_Days ngày</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script type="text/javascript">
    $(document).ready(function () {
        var rawData = @Html.Raw(ViewBag.ChartData ?? "[]");
        if ($("#placeholder2").length > 0 && rawData.length > 0) {
            $.plot($("#placeholder2"), rawData, {
                series: { pie: { show: true, innerRadius: 0.4 } },
                legend: { show: true }
            });
        }
    });
</script>