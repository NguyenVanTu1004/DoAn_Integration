@using HRWebApp.Models
@model IEnumerable<HRWebApp.Models.EmployeeViewModel>

@{
    ViewBag.Title = "CEO Strategic Dashboard | Integrated HR & Payroll";
}

<style>
    :root {
        --primary: #2c3e50;
        --success: #27ae60;
        --warning: #f39c12;
        --danger: #e74c3c;
        --info: #3498db;
    }

    .content {
        background: #f4f7f6;
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    .stat-card {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: 0.3s;
        border-top: 4px solid var(--primary);
        min-height: 130px;
        overflow: hidden;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 20px rgba(0,0,0,0.1);
    }

    .stat-card.hr { border-top-color: var(--success); }
    .stat-card.payroll { border-top-color: var(--warning); }
    .stat-card.alert { border-top-color: var(--danger); }

    .stat-value {
        font-size: 20px;
        font-weight: bold;
        display: block;
        margin: 10px 0;
        color: #333;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .stat-label {
        color: #7f8c8d;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 1px;
    }

    .alert-strip {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
        padding: 15px 25px;
        border-radius: 50px;
        margin-bottom: 25px;
        border: 1px solid #e1e4e8;
    }

    .alert-item {
        display: flex;
        align-items: center;
        gap: 10px;
        cursor: pointer;
        padding: 5px 15px;
        border-radius: 20px;
        transition: 0.2s;
    }

    .alert-item:hover { background: #f0f0f0; }

    .alert-count {
        background: var(--danger);
        color: #fff;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 12px;
    }

    /* DataTable Formatting */
    .dataTables_wrapper .dataTables_filter { float: right; margin-bottom: 10px; }
    .dataTables_wrapper .dataTables_length { float: left; margin-bottom: 10px; }
    .dataTables_wrapper .dataTables_info { float: left; margin-top: 10px; }
    .dataTables_wrapper .dataTables_paginate { float: right; margin-top: 10px; }

    #placeholder {
        width: 100% !important;
        min-height: 350px !important;
        height: 350px !important;
        display: block !important;
    }
</style>

<div class="content">
    <div class="container-fluid">
        <div class="alert-strip">
            <span class="stat-label"><i class="icon-bell"></i> Critical Alerts:</span>
            <div class="alert-item" onclick="location.href='@Url.Action("AlertVacation", "Admin")'">
                <i class="icon-plane text-warning"></i> <span>Over Vacation</span>
                <span class="alert-count">@ViewBag.OverVacationCount</span>
            </div>
            <div class="alert-item" onclick="location.href='@Url.Action("AlertAnniversary", "Admin")'">
                <i class="icon-gift text-info"></i> <span>Anniversaries</span>
                <span class="alert-count">@ViewBag.AnniversaryCount</span>
            </div>
            <div class="alert-item" onclick="location.href='@Url.Action("AlertBirthday", "Admin")'">
                <i class="icon-calendar text-success"></i> <span>Birthdays</span>
                <span class="alert-count">@ViewBag.BirthdayCount</span>
            </div>
            <a href="@Url.Action("SeedData", "Admin")" class="btn btn-primary" onclick="return startSync(this);">
                <i class="icon-refresh"></i> SYNC MASTER DATA
            </a>
        </div>

        <div class="row-fluid">
            <div class="span3 stat-card hr">
                <span class="stat-label">Total Workforce</span>
                <span class="stat-value">@String.Format("{0:N0}", ViewBag.TotalUsers)</span>
                <div class="progress progress-mini"><div class="bar bar-success" style="width: 100%;"></div></div>
            </div>
            <div class="span3 stat-card payroll">
                <span class="stat-label">Total Earnings (YTD)</span>
                <span class="stat-value" title="@ViewBag.TotalSalary">@ViewBag.TotalSalary</span>
                <span class="text-success" style="font-size:12px;"><i class="icon-caret-up"></i> +4.2% from Prev Year</span>
            </div>
            <div class="span3 stat-card hr">
                <span class="stat-label">Avg Benefits Paid</span>
                <span class="stat-value">$ @ViewBag.AvgBenefits</span>
                <span class="stat-label">By Benefit Plan</span>
            </div>
            <div class="span3 stat-card alert">
                <span class="stat-label">Vacation Liability</span>
                <span class="stat-value">@ViewBag.TotalVacationDays Days</span>
                <span class="stat-label">Total accumulated</span>
            </div>
        </div>

        <br />

        <div class="row-fluid">
            <div class="span12">
                <div id="placeholder"></div>
            </div>
        </div>

        <div class="module">
            <div class="module-head">
                <div class="pull-right">
                    <button type="button" class="btn btn-small btn-success" onclick="fetchIntegrityData(this)">
                        <i class="icon-download-alt"></i> FETCH & SYNC DATA
                    </button>
                </div>
                <h3><i class="icon-dashboard"></i> Integrated Master Data Monitoring</h3>
            </div>
            <div class="module-body table">
                <table id="masterTable" class="table table-bordered table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Employee Details</th>
                            <th>Demographics</th>
                            <th>Job Status</th>
                            <th>Payroll (MySQL)</th>
                            <th>HR Data (SQL)</th>
                            <th>Integrity</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        // 1. Đồng bộ nút Master Data trên cùng
        function startSync(btn) {
            if (confirm("Confirm Synchronization? This will reconcile records between HR and Payroll.")) {
                $(btn).addClass('disabled').html('<i class="icon-spinner icon-spin"></i> Synchronizing...');
                return true;
            }
            return false;
        }

        // 2. Fetch data bất đồng bộ cho bảng
        function fetchIntegrityData(btn) {
            var $btn = $(btn);
            var originalHtml = '<i class="icon-download-alt"></i> FETCH & SYNC DATA';

            $btn.addClass('disabled').prop('disabled', true).html('<i class="icon-spinner icon-spin"></i> Processing...');

            $.ajax({
                url: '@Url.Action("SeedData", "Admin")',
                type: 'POST',
                success: function (response) {
                    if (response.success) {
                        alert("✅ Thành công: Dữ liệu đã được nạp vào kho chứa.");
                        $('#masterTable').DataTable().ajax.reload();
                    } else {
                        alert("❌ Lỗi: " + response.message);
                    }
                },
                error: function () { alert("❌ Lỗi kết nối API."); },
                complete: function () {
                    $btn.removeClass('disabled').prop('disabled', false).html(originalHtml);
                }
            });
        }

        (function($) {
            $(function() {
                // Khởi tạo bảng với Server-side Paging 20 dòng
                initDataTable();
                // Khởi tạo biểu đồ an toàn
                handleChartsDefensive();
            });

            function initDataTable() {
                var $table = $('#masterTable');
                if (!$table.length) return;

                $table.DataTable({
                    "processing": true,
                    "serverSide": true,
                    "pageLength": 20,
                    "pagingType": "full_numbers",
                    "ajax": {
                        "url": "@Url.Action("GetEmployeesData", "Admin")",
                        "type": "POST",
                        "data": function (d) {
                            // Gửi thêm filterType nếu CEO bấm vào các nút Alert
                            d.filterType = "@ViewBag.ReportType";
                            return d;
                        }
                    },
                    "columns": [
                        { "data": "id" },
                        { 
                            "data": "fullName",
                            "render": function(data) { return "<b>" + (data || "N/A") + "</b>"; }
                        },
                        { "data": "ethnicity" },
                        { 
                            "data": "status",
                            "render": function(d) {
                                var cls = (d === "Full-time") ? "label-info" : "label-warning";
                                return '<span class="label ' + cls + '">' + (d || "Active") + '</span>';
                            }
                        },
                        {
                            "data": "salaryInSql",
                            "render": function(d) {
                                return "<b>$" + (parseFloat(d) || 0).toLocaleString() + "</b>";
                            }
                        },
                        { "data": "vacationDays" },
                        {
                            "data": null,
                            "render": function () {
                                return '<span class="label label-success">Integrated</span>';
                            }
                        }
                    ],
                    "language": {
                        "processing": "Đang nạp 20 bản ghi...",
                        "zeroRecords": "Không tìm thấy dữ liệu nhân sự"
                    }
                });
            }

            function handleChartsDefensive() {
                const container = document.getElementById('placeholder');
                if (!container) return;

                const checkAndResize = () => {
                    if (container.offsetWidth > 0 && container.offsetHeight > 0) {
                        try {
                            $(window).trigger('resize');
                            if (typeof renderChart === "function") renderChart();
                        } catch (e) { console.warn("Chart delay..."); }
                    } else {
                        requestAnimationFrame(checkAndResize);
                    }
                };
                requestAnimationFrame(checkAndResize);
            }
        })(jQuery);
    </script>
}