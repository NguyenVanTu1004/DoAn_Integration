@using HRWebApp.Models
@model IEnumerable<HRWebApp.Models.EmployeeViewModel>

@{
    ViewBag.Title = "CEO Strategic Dashboard | Integrated HR & Payroll";
}

<style>
    :root {
        --primary: #2c3e50;
        --success: #27ae60;
        --warning: #f39c12;
        --danger: #e74c3c;
        --info: #3498db;
    }

    .content {
        background: #f4f7f6;
        padding: 20px;
        font-family: 'Segoe UI', sans-serif;
    }

    /* KPI Cards Design */
    .stat-card {
        background: #fff;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        transition: 0.3s;
        border-top: 4px solid var(--primary);
        min-height: 130px;
        position: relative;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 20px rgba(0,0,0,0.1);
        }

        .stat-card.hr {
            border-top-color: var(--success);
        }

        .stat-card.payroll {
            border-top-color: var(--warning);
        }

        .stat-card.alert {
            border-top-color: var(--danger);
        }

    .stat-value {
        font-size: 24px;
        font-weight: bold;
        display: block;
        margin: 10px 0;
        color: #2c3e50;
    }

    .stat-label {
        color: #7f8c8d;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 1.2px;
        font-weight: 600;
    }

    /* Alert Strip Styling */
    .alert-strip {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fff;
        padding: 12px 25px;
        border-radius: 50px;
        margin-bottom: 25px;
        border: 1px solid #e1e4e8;
    }

    .alert-item {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        padding: 6px 15px;
        border-radius: 20px;
        transition: 0.2s;
    }

        .alert-item:hover {
            background: #f8f9fa;
            color: var(--info);
        }

    .alert-count {
        background: var(--danger);
        color: #fff;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 11px;
        font-weight: bold;
    }

    /* Chart & Table Module */
    .module {
        background: #fff;
        border: 1px solid #e1e4e8;
        border-radius: 4px;
        margin-bottom: 20px;
    }

    .module-head {
        background: #fbfbfb;
        padding: 10px 15px;
        border-bottom: 1px solid #e1e4e8;
    }

        .module-head h3 {
            font-size: 14px;
            color: #333;
            margin: 0;
            line-height: 30px;
        }

    #placeholder {
        width: 100% !important;
        height: 350px !important;
        display: block;
    }

    .label-sync {
        background-color: #27ae60 !important;
        font-size: 10px;
        text-transform: uppercase;
    }
</style>

<div class="content">
    <div class="container-fluid">

        @* --- PHẦN 1: THÔNG BÁO TỪ HỆ THỐNG ĐỐI SOÁT --- *@
        <div class="alert-strip">
            <span class="stat-label"><i class="icon-bolt"></i> IQ-RECONCILE ALERTS:</span>
            <div class="alert-item" onclick="filterTable('Vacation')">
                <i class="icon-plane text-warning"></i> <span>Leave Liability</span>
                <span class="alert-count">@ViewBag.OverVacationCount</span>
            </div>
            <div class="alert-item" onclick="filterTable('Anniversary')">
                <i class="icon-trophy text-info"></i> <span>Anniversaries</span>
                <span class="alert-count">@ViewBag.AnniversaryCount</span>
            </div>
            <div class="alert-item" onclick="filterTable('Birthday')">
                <i class="icon-gift text-success"></i> <span>Birthdays</span>
                <span class="alert-count">@ViewBag.BirthdayCount</span>
            </div>
            <button type="button" class="btn btn-primary" onclick="triggerMasterSync(this)">
                <i class="icon-refresh"></i> RUN FULL RECONCILIATION
            </button>
        </div>

        @* --- PHẦN 2: CHỈ SỐ KPI ĐÃ HỢP NHẤT (INTEGRATED) --- *@
        <div class="row-fluid">
            <div class="span3 stat-card hr">
                <span class="stat-label">Verified Workforce</span>
                <span class="stat-value">@String.Format("{0:N0}", ViewBag.TotalUsers)</span>
                <div class="progress progress-mini"><div class="bar bar-success" style="width: 100%;"></div></div>
            </div>
            <div class="span3 stat-card payroll">
                <span class="stat-label">Total Payroll Liability</span>
                <span class="stat-value">@ViewBag.TotalSalary</span>
                <span class="text-success" style="font-size:11px;"><i class="icon-ok-sign"></i> 100% Reconciled</span>
            </div>
            <div class="span3 stat-card hr">
                <span class="stat-label">Avg Benefit Package</span>
                <span class="stat-value">$ @ViewBag.AvgBenefits</span>
                <span class="stat-label" style="font-size:9px">Consolidated Plan</span>
            </div>
            <div class="span3 stat-card alert">
                <span class="stat-label">Financial Liability (Leave)</span>
                <span class="stat-value">@ViewBag.TotalVacationDays Days</span>
                <span class="stat-label" style="font-size:9px">Estimated payoff value</span>
            </div>
        </div>

        <br />

        @* --- PHẦN 3: PHÂN TÍCH CHIẾN LƯỢC CHO CEO --- *@
        <div class="row-fluid">
            <div class="span12">
                <div class="module">
                    <div class="module-head">
                        <div class="pull-right">
                            <select id="chartSelector" style="margin-top:-5px; height:25px; font-size:11px; width:220px;">
                                <option value="ethnicity">Distribution by Ethnicity</option>
                                <option value="gender">Gender Diversity Ratio</option>
                                <option value="pay_rate">Pay Rate Tier Analysis</option>
                            </select>
                        </div>
                        <h3><i class="icon-bar-chart"></i> Executive Data Insight</h3>
                    </div>
                    <div class="module-body">
                        <div id="placeholder"></div>
                    </div>
                </div>
            </div>
        </div>

        @* --- PHẦN 4: MASTER INTEGRATED TABLE --- *@
        <div class="module">
            <div class="module-head">
                <h3><i class="icon-table"></i> Master Integrated Data Set (Post-Reconciliation)</h3>
            </div>
            <div class="module-body table">
                <table id="masterTable" class="table table-bordered table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Employee Name</th>
                            <th>Gender</th>
                            <th>Ethnicity</th>
                            <th>Status</th>
                            <th>Verified Salary</th>
                            <th>Leave Bal.</th>
                            <th>Integrity</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @* Thứ tự nạp Script tối ưu *@
    <script src="https://code.jquery.com/jquery-1.12.4.min.js"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.10.24/css/jquery.dataTables.css">
    <script type="text/javascript" src="https://cdn.datatables.net/1.10.24/js/jquery.dataTables.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flot/0.8.3/jquery.flot.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/flot/0.8.3/jquery.flot.pie.min.js"></script>

    <script type="text/javascript">
        var masterTable;

        $(document).ready(function() {
            // 1. KHỞI TẠO BẢNG MASTER (Sử dụng API của Hệ thống 3)
            masterTable = $('#masterTable').DataTable({
                "processing": true,
                "serverSide": true,
                "pageLength": 10,
                "ajax": {
                    "url": "@Url.Action("GetEmployeesData", "Admin")",
                    "type": "POST",
                    "data": function (d) {
                        d.filterType = window.currentFilter || 'All';
                        return d;
                    }
                },
                "columns": [
                    { "data": "id" },
                    { "data": "fullName", "render": function(d) { return "<b>"+d+"</b>"; } },
                    { "data": "gender" },
                    { "data": "ethnicity" },
                    { "data": "status", "render": function(d) { return '<span class="label">'+d+'</span>'; } },
                    { "data": "salaryInSql", "render": function(d) { return "<b>$" + parseFloat(d).toLocaleString() + "</b>"; } },
                    { "data": "vacationDays", "render": function(d) { return d + " d"; } },
                    { "data": null, "defaultContent": '<span class="label label-sync"><i class="icon-ok"></i> Verified</span>' }
                ],
                "language": { "processing": "<i class='icon-spinner icon-spin'></i> Syncing Master Data..." }
            });

            // 2. Khởi tạo Biểu đồ
            renderStrategicChart();
            $('#chartSelector').change(renderStrategicChart);
        });

        // HÀM LỌC DỮ LIỆU TỪ ALERTS
        function filterTable(type) {
            window.currentFilter = type;
            masterTable.ajax.reload();
            // Cuộn xuống bảng để CEO dễ nhìn
            $('html, body').animate({ scrollTop: $("#masterTable").offset().top - 100 }, 500);
        }

        // HÀM CHẠY ĐỐI SOÁT TOÀN DIỆN
        function triggerMasterSync(btn) {
            var $btn = $(btn);
            if (!confirm("Start full reconciliation between HR & Payroll?")) return;

            $btn.addClass('disabled').html('<i class="icon-spinner icon-spin"></i> RECONCILING...');

            $.post('@Url.Action("SeedData", "Admin")', function (res) {
                if (res.success) {
                    alert("✅ Integration Successful: All records matched and updated.");
                    location.reload(); // Reload để cập nhật KPI Cards
                } else {
                    alert("❌ Error: " + res.message);
                    $btn.removeClass('disabled').html('<i class="icon-refresh"></i> RUN FULL RECONCILIATION');
                }
            });
        }

        // VẼ BIỂU ĐỒ CEO
        function renderStrategicChart() {
            var type = $('#chartSelector').val();
            $.ajax({
                url: 'http://127.0.0.1:3000/api/mysql/chart-data', // Vẫn lấy từ Node để giảm tải cho C#
                type: 'GET',
                data: { type: type },
                success: function (response) {
                    var $cont = $("#placeholder");
                    if ($cont.width() > 0) {
                        $.plot($cont, response, {
                            series: { pie: { show: true, innerRadius: 0.4, label: { show: true, radius: 0.75,
                                formatter: function(l, s) { return '<div style="font-size:10px;color:white;text-align:center;padding:2px;">'+l+'<br/>'+Math.round(s.percent)+'%</div>'; },
                                background: { opacity: 0.5, color: '#000' }
                            }}},
                            legend: { show: true }
                        });
                    }
                }
            });
        }
    </script>
}